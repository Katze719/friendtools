# Postgres
POSTGRES_USER=friendflow
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=friendflow

# Backend
DATABASE_URL=postgres://friendflow:change_me_please@db:5432/friendflow
JWT_SECRET=please_generate_a_long_random_string_here_min_32_chars
JWT_EXPIRY_HOURS=1068
BIND_ADDR=0.0.0.0:3000
# Not strictly required when frontend and backend share an origin via the
# bundled nginx proxy (default docker-compose setup). Set it anyway as a
# defence-in-depth measure and for browser tooling during dev. Comma-separated.
# Example for production: https://friendtools.site,https://www.friendtools.site
CORS_ORIGIN=http://localhost:8080
RUST_LOG=info,tower_http=info,sqlx=warn

# How new sign-ups are handled:
#   approval (default) - new accounts are "pending" until an admin approves
#                        them. Safe for private instances.
#   open               - new accounts are auto-approved and can sign in
#                        immediately. Use for public / self-hosted demos.
REGISTRATION_MODE=approval

# --- Password recovery ---
# If SMTP_HOST is set, the login screen offers a "Forgot password?" link
# that emails a one-hour, single-use reset link. Leave SMTP_HOST empty to
# fully disable the feature (the link won't appear).
#
# APP_BASE_URL must be the public URL of your frontend - it's used to
# build the reset link in the outbound mail. Without it we fall back to
# the first entry from CORS_ORIGIN, which is fine for local docker setups
# but you should set it explicitly in production.
#APP_BASE_URL=https://friendflow.example
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
# starttls (default), tls (implicit, usually port 465), or none (dev only)
#SMTP_ENCRYPTION=starttls
#SMTP_USERNAME=apikey
#SMTP_PASSWORD=your_smtp_password
# Either a bare address or a "Name <address>" mailbox.
#SMTP_FROM=friendflow <noreply@friendflow.example>

# Frontend
# Empty = same-origin (nginx proxies /api to the backend). Set only for non-docker dev.
VITE_API_URL=

# Controls what unauthenticated visitors see at "/".
#   login   (default) - redirect straight to the sign-in form.
#   landing           - public marketing page explaining what friendflow
#                       is, with sign-in / sign-up buttons in the top right.
# Useful when the instance is exposed to the open web.
LANDING_MODE=login
